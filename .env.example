# Everything here has a sensible default — the app runs with NO .env at all.
# Copy to packages/server/.env only to override.

NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
API_URL=http://localhost:4000

# ─── Database ────────────────────────────────────────────────────────────
# The app bundles an embedded Postgres and starts it automatically (no Docker,
# no install). Data is stored in packages/server/data/pg.
DATABASE_URL=postgresql://cc:cc@127.0.0.1:54329/claude_control?schema=public
EMBEDDED_PG=true
PG_DATA_DIR=./data/pg
# To use an EXTERNAL Postgres instead: set EMBEDDED_PG=false and point
# DATABASE_URL at your instance.

# ─── Security ────────────────────────────────────────────────────────────
# 32-byte key, base64. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=CHANGE_ME_base64_32_bytes
SESSION_SECRET=CHANGE_ME_random_string

# ─── AI provider ─────────────────────────────────────────────────────────
LLM_PROVIDER_MODE=apikey
SELF_HOSTED=false
ANTHROPIC_API_KEY=

# ─── Storage ─────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
