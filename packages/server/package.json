{
  "name": "@cc/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "serve": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.206",
    "@anthropic-ai/sdk": "^0.111.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.19.0",
    "@xenova/transformers": "^2.17.2",
    "argon2": "^0.44.0",
    "cookie": "^1.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron-parser": "^4.9.0",
    "docx": "^9.7.1",
    "dotenv": "^16.4.7",
    "embedded-postgres": "^18.4.0-beta.17",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "imapflow": "^1.4.7",
    "localtunnel": "^2.0.2",
    "multer": "^2.0.1",
    "nodemailer": "^6.10.1",
    "officeparser": "^7.3.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.19.1",
    "pptxgenjs": "^4.0.1",
    "socket.io": "^4.8.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "prisma": "^6.19.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
