{
  "name": "claude-control",
  "version": "0.1.4",
  "private": true,
  "description": "Claude Control desktop shell (Electron).",
  "author": "Claude Control",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "stage": "node scripts/stage.mjs",
    "pack": "node scripts/stage.mjs && electron-builder --dir",
    "dist": "node scripts/stage.mjs && electron-builder",
    "release": "node scripts/stage.mjs && electron-builder --publish always",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.claudecontrol.app",
    "productName": "Claude Control",
    "electronVersion": "33.4.11",
    "npmRebuild": false,
    "includeSubNodeModules": true,
    "compression": "normal",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "staged/server/**/*",
      "staged/web/**/*"
    ],
    "asarUnpack": [
      "staged/server/node_modules/@embedded-postgres/**",
      "staged/server/node_modules/@anthropic-ai/claude-agent-sdk-*/**",
      "staged/server/node_modules/.prisma/**",
      "staged/server/node_modules/@prisma/**",
      "staged/server/node_modules/**/*.node",
      "staged/server/node_modules/**/*.exe",
      "staged/server/node_modules/**/*.dll"
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "Jurvdw",
        "repo": "claude-control",
        "releaseType": "release"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Claude Control"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
